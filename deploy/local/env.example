# Local LaunchAgents deployment defaults.
# Copy to deploy/local/env.local only if you need to override values.

SHENGJI_PROJECT_DIR="/Users/way/Desktop/99-生机大模型"
SHENGJI_LOG_DIR="${HOME}/Library/Logs/Shengji"

QDRANT_HTTP_PORT="6333"
QDRANT_GRPC_PORT="6334"
MINERU_PORT="8000"
ENZYME_API_PORT="8001"
SHENGJI_WEB_PORT="5173"

ENZYME_RUNTIME_CONFIG="configs/local.yaml"
# Use cpu to force MinerU seal OCR onto seal_lite when the local seal server
# weight cache has a state_dict shape mismatch on MPS/CUDA.
MINERU_DEVICE_MODE="cpu"
MINERU_ENABLE_VLM_PRELOAD="false"
SHENGJI_LOG_MAX_BYTES="52428800"
SHENGJI_LOG_RETENTION_DAYS="14"
INGESTION_POLL_SECONDS="10"
INGESTION_MINERU_TIMEOUT_SECONDS="1800"
INGESTION_MINERU_INTERVAL_SECONDS="10"
INGESTION_QDRANT_BATCH_SIZE="64"
# Leave empty to follow ENZYME_RUNTIME_CONFIG. Set to enzyme_immobilization_literature
# only when intentionally rolling ingestion back to the hash_v1 baseline.
INGESTION_COLLECTION=""
