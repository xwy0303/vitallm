flowchart TD
  A["学生：收集并登记论文 PDF"] --> B["系统：自动解析 PDF"]
  B --> C["系统：抽取候选 evidence"]
  C --> D{"是否有质量风险？"}
  D -- "无明显风险" --> E["进入候选知识库"]
  D -- "OCR / 数值 / 表格异常" --> F["进入 review queue"]
  F --> G["学生：核对原文、表格、图片"]
  G --> H["学生：确认 / 修正 / 标记不可用"]
  H --> I["教师或项目负责人抽检"]
  I --> J["沉淀为可追溯知识库"]
  J --> K["LLM：固定化剂推荐与配方优化"]
